# L1+L2+L3 verification Job. The orchestrator renders this template by
# substituting __NS__ with the target namespace and applies it.
#
# Exits 0 only if every check below passes:
#   L2 — Service-level reachability (web HTTP, api HTTP, cache PING)
#   L3 — End-to-end:
#         - web -> api round-trip via nginx proxy_pass
#         - db write+read via psql
#         - queue-worker has pushed entries to redis
#         - cron-pinger has recorded a success
#
# Image: postgres:16-alpine ships psql + bash. We apk-add curl +
# redis (for redis-cli) at runtime — ~3-5 second install per run.
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: workload-verify
  namespace: __NS__
automountServiceAccountToken: false
---
apiVersion: batch/v1
kind: Job
metadata:
  name: workload-verify
  namespace: __NS__
  labels:
    app: workload-verify
spec:
  ttlSecondsAfterFinished: 600
  backoffLimit: 0
  template:
    metadata:
      labels:
        app: workload-verify
    spec:
      serviceAccountName: workload-verify
      restartPolicy: Never
      securityContext:
        runAsNonRoot: true
        runAsUser: 70
        runAsGroup: 70
        fsGroup: 70
        seccompProfile: { type: RuntimeDefault }
      containers:
        - name: verify
          image: docker.io/library/postgres:16-alpine
          imagePullPolicy: IfNotPresent
          securityContext:
            allowPrivilegeEscalation: false
            # apk needs to write under /var/cache/apk + /etc/apk; we
            # provide writable scratch via emptyDir mounts. The actual
            # binary layout (/usr/bin etc.) stays read-only.
            readOnlyRootFilesystem: true
            capabilities: { drop: [ALL] }
          resources:
            requests: { cpu: 50m, memory: 64Mi }
            limits:   { cpu: 200m, memory: 256Mi }
          env:
            - name: PGPASSWORD
              valueFrom:
                secretKeyRef:
                  name: db-credentials
                  key: password
          volumeMounts:
            - { name: scratch,   mountPath: /tmp }
            - { name: apk-cache, mountPath: /var/cache/apk }
            - { name: apk-local, mountPath: /usr/local }
            # apk needs to update /etc/apk on install. Mounting an
            # emptyDir on /etc isn't an option (loses /etc/passwd
            # etc.); instead we install into a writable prefix via
            # `apk --root /tmp/sysroot add ...`.
          command: ["bash", "-euo", "pipefail", "-c"]
          args:
            - |
              # Install curl + redis-cli into a tmp sysroot so we don't
              # need to write to /etc or /var/lib/apk on the (read-only)
              # rootfs. The sysroot's binaries are then on PATH.
              mkdir -p /tmp/sysroot
              apk --root /tmp/sysroot --no-cache --initdb \
                  add curl redis ca-certificates 2>&1 | tail -3
              export PATH=/tmp/sysroot/usr/bin:/tmp/sysroot/usr/sbin:$PATH

              FAILED=0
              fail() { echo "FAIL: $*" >&2; FAILED=1; }
              ok()   { echo "OK:   $*"; }

              echo "===== L2: Service-level reachability ====="
              if curl -sf -m 5 http://web.__NS__.svc.cluster.local:8080/ >/tmp/web.html; then
                ok "web Service serves HTTP 200"
              else
                fail "web Service unreachable or non-200"
              fi
              if curl -sf -m 5 http://api.__NS__.svc.cluster.local/get >/tmp/api.json; then
                ok "api Service serves HTTP 200"
              else
                fail "api Service unreachable or non-200"
              fi
              if redis-cli -h cache.__NS__.svc.cluster.local PING | grep -q PONG; then
                ok "cache Service responds to PING"
              else
                fail "cache Service did not PONG"
              fi

              echo "===== L3: End-to-end functional ====="
              if curl -sf -m 5 http://web.__NS__.svc.cluster.local:8080/api/get | grep -q '"url"'; then
                ok "web -> api round-trip succeeds (nginx proxy_pass)"
              else
                fail "web -> api proxy_pass broken"
              fi

              psql "host=db-0.db.__NS__.svc.cluster.local user=postgres dbname=postgres" \
                -c "CREATE TABLE IF NOT EXISTS verify_smoke (id serial primary key, ts timestamptz default now());" \
                -c "INSERT INTO verify_smoke DEFAULT VALUES RETURNING id;" \
                -c "SELECT count(*) FROM verify_smoke;" >/tmp/db.out 2>&1 \
                && ok "db write+read succeeded" \
                || fail "db round-trip failed (see /tmp/db.out)"

              QLEN=$(redis-cli -h cache.__NS__.svc.cluster.local LLEN queue-worker || echo 0)
              if [ "${QLEN:-0}" -gt 0 ]; then
                ok "queue-worker has pushed $QLEN entries to redis"
              else
                fail "queue-worker has not pushed anything to redis yet"
              fi

              LAST_PING=$(redis-cli -h cache.__NS__.svc.cluster.local GET cron-pinger:last-success || echo "")
              if [ -n "$LAST_PING" ]; then
                ok "cron-pinger last success: $LAST_PING"
              else
                fail "cron-pinger has not recorded a success yet"
              fi

              echo "===== Summary ====="
              if [ $FAILED -eq 0 ]; then
                echo "ALL CHECKS PASSED for namespace __NS__"
                exit 0
              else
                echo "FAILURES recorded in namespace __NS__"
                cat /tmp/db.out 2>/dev/null || true
                exit 1
              fi
      volumes:
        - name: scratch
          emptyDir: {}
        - name: apk-cache
          emptyDir: {}
        - name: apk-local
          emptyDir: {}
