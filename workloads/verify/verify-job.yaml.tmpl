# L1+L2+L3 verification Job. The orchestrator renders this template by
# substituting __NS__ with the target namespace and applies it.
#
# Exits 0 only if every check below passes:
#   L2 — Service-level reachability (web HTTP, api HTTP, cache PING)
#   L3 — End-to-end:
#         - web -> api round-trip via nginx proxy_pass
#         - db write+read via psql
#         - queue-worker has pushed entries to redis
#         - cron-pinger has recorded a success
#
# Image: postgres:16-alpine ships psql + bash. We apk-add curl +
# redis (for redis-cli) at runtime — ~3-5 second install per run.
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: workload-verify
  namespace: __NS__
automountServiceAccountToken: false
---
apiVersion: batch/v1
kind: Job
metadata:
  name: workload-verify
  namespace: __NS__
  labels:
    app: workload-verify
spec:
  ttlSecondsAfterFinished: 600
  backoffLimit: 0
  template:
    metadata:
      labels:
        app: workload-verify
    spec:
      serviceAccountName: workload-verify
      restartPolicy: Never
      securityContext:
        runAsNonRoot: true
        runAsUser: 70
        runAsGroup: 70
        fsGroup: 70
        seccompProfile: { type: RuntimeDefault }
      containers:
        - name: verify
          image: docker.io/library/postgres:16-alpine
          imagePullPolicy: IfNotPresent
          securityContext:
            allowPrivilegeEscalation: false
            # apk needs to write under /var/cache/apk + /etc/apk; we
            # provide writable scratch via emptyDir mounts. The actual
            # binary layout (/usr/bin etc.) stays read-only.
            readOnlyRootFilesystem: true
            capabilities: { drop: [ALL] }
          resources:
            requests: { cpu: 50m, memory: 64Mi }
            limits:   { cpu: 200m, memory: 256Mi }
          env:
            - name: PGPASSWORD
              valueFrom:
                secretKeyRef:
                  name: db-credentials
                  key: password
          volumeMounts:
            - { name: scratch,   mountPath: /tmp }
            - { name: apk-cache, mountPath: /var/cache/apk }
            # NOTE: do NOT mount anything at /usr/local — that path
            # contains the postgres image's own bin/psql, and an
            # emptyDir overlay would shadow it. The earlier
            # apk-local mount turned out to be unnecessary because
            # we install into /tmp/sysroot, not /usr/local.
          command: ["bash", "-euo", "pipefail", "-c"]
          args:
            - |
              # Tooling strategy: use what postgres:16-alpine already
              # ships, install only what's missing.
              #   wget    — busybox built-in. Use INSTEAD of curl, which
              #             had RPATH problems when apk-installed into
              #             /tmp/sysroot (libcurl can't be found).
              #   psql    — at /usr/local/bin/psql in the postgres image.
              #             Some images strip /usr/local from non-login
              #             PATH; we use the absolute path to be safe.
              #   redis-cli — not in the postgres image. apk install,
              #               which is the one place the sysroot trick
              #               does work (statically linked enough).
              mkdir -p /tmp/sysroot/etc/apk
              cp /etc/apk/repositories /tmp/sysroot/etc/apk/repositories
              cp -r /etc/apk/keys /tmp/sysroot/etc/apk/keys
              apk --root /tmp/sysroot --usermode --no-cache --initdb \
                  --no-scripts add redis 2>&1 | tail -3

              # Use full paths so PATH inheritance / env quirks can't bite.
              REDIS_CLI=/tmp/sysroot/usr/bin/redis-cli
              PSQL=/usr/local/bin/psql
              # Sanity check.
              [ -x "$REDIS_CLI" ] || { echo "FATAL: $REDIS_CLI missing" >&2; exit 1; }
              [ -x "$PSQL" ]      || { echo "FATAL: $PSQL missing" >&2; exit 1; }
              command -v wget >/dev/null || { echo "FATAL: busybox wget missing?" >&2; exit 1; }

              FAILED=0
              fail() { echo "FAIL: $*" >&2; FAILED=1; }
              ok()   { echo "OK:   $*"; }

              echo "===== L2: Service-level reachability ====="
              if wget -qO /tmp/web.html --timeout=5 --tries=1 http://web.__NS__.svc.cluster.local:8080/; then
                ok "web Service serves HTTP 200"
              else
                fail "web Service unreachable or non-200"
              fi
              if wget -qO /tmp/api.json --timeout=5 --tries=1 http://api.__NS__.svc.cluster.local/get; then
                ok "api Service serves HTTP 200"
              else
                fail "api Service unreachable or non-200"
              fi
              if "$REDIS_CLI" -h cache.__NS__.svc.cluster.local PING | grep -q PONG; then
                ok "cache Service responds to PING"
              else
                fail "cache Service did not PONG"
              fi

              echo "===== L3: End-to-end functional ====="
              if wget -qO- --timeout=5 --tries=1 http://web.__NS__.svc.cluster.local:8080/api/get | grep -q '"url"'; then
                ok "web -> api round-trip succeeds (nginx proxy_pass)"
              else
                fail "web -> api proxy_pass broken"
              fi

              # Use the headless Service name (resolves to pod IPs) rather
              # than the pod FQDN db-0.db.<NS>.svc.cluster.local. psql
              # via musl libc occasionally fails to translate the latter
              # even when wget/redis-cli can — the Service name is
              # boring DNS that works universally.
              "$PSQL" "host=db.__NS__.svc.cluster.local user=postgres dbname=postgres" \
                -c "CREATE TABLE IF NOT EXISTS verify_smoke (id serial primary key, ts timestamptz default now());" \
                -c "INSERT INTO verify_smoke DEFAULT VALUES RETURNING id;" \
                -c "SELECT count(*) FROM verify_smoke;" >/tmp/db.out 2>&1 \
                && ok "db write+read succeeded" \
                || fail "db round-trip failed (see /tmp/db.out)"

              QLEN=$("$REDIS_CLI" -h cache.__NS__.svc.cluster.local LLEN queue-worker || echo 0)
              if [ "${QLEN:-0}" -gt 0 ]; then
                ok "queue-worker has pushed $QLEN entries to redis"
              else
                fail "queue-worker has not pushed anything to redis yet"
              fi

              # cron-pinger fires every 1 min; on a freshly-deployed
              # tenant the verify Job may run before the first tick.
              # Retry up to ~90s so we don't fail on what's purely a
              # cold-start timing issue.
              LAST_PING=""
              for i in 1 2 3 4 5 6 7 8 9; do
                LAST_PING=$("$REDIS_CLI" -h cache.__NS__.svc.cluster.local \
                    GET cron-pinger:last-success || echo "")
                [ -n "$LAST_PING" ] && break
                echo "    (cron-pinger not yet, retry $i/9 in 10s)"
                sleep 10
              done
              if [ -n "$LAST_PING" ]; then
                ok "cron-pinger last success: $LAST_PING"
              else
                fail "cron-pinger has not recorded a success after ~90s wait"
              fi

              echo "===== Summary ====="
              if [ $FAILED -eq 0 ]; then
                echo "ALL CHECKS PASSED for namespace __NS__"
                exit 0
              else
                echo "FAILURES recorded in namespace __NS__"
                cat /tmp/db.out 2>/dev/null || true
                exit 1
              fi
      volumes:
        - name: scratch
          emptyDir: {}
        - name: apk-cache
          emptyDir: {}
